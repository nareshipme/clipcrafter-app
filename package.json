{
  "name": "clipcrafter-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/lib-storage": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@clerk/nextjs": "^7.0.5",
    "@google/generative-ai": "^0.24.1",
    "@remotion/bundler": "^4.0.438",
    "@remotion/captions": "^4.0.438",
    "@remotion/renderer": "^4.0.438",
    "@supabase/supabase-js": "^2.99.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@xyflow/react": "^12.10.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "groq-sdk": "^1.1.1",
    "inngest": "^3.52.7",
    "next": "16.2.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
